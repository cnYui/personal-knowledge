# Database Configuration
DATABASE_URL=sqlite:///./app.db

# Upload Configuration
UPLOAD_DIR=backend/uploads/images

# Knowledge Graph Configuration (Legacy)
KNOWLEDGE_GRAPH_BASE_URL=http://localhost:8001

# Multimodal Configuration
MULTIMODAL_PROVIDER=mock
MULTIMODAL_API_KEY=

# OCR Configuration
OCR_ENABLED=true

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# StepFun API Configuration (compatible with OpenAI SDK, required by Graphiti)
OPENAI_API_KEY=your-stepfun-api-key-here
OPENAI_BASE_URL=https://api.stepfun.com/v1
