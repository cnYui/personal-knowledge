# Database Configuration
DATABASE_URL=postgresql+psycopg://pkb_user:pkb_password@localhost:5432/personal_knowledge_base

# Upload Configuration
UPLOAD_DIR=backend/uploads/images

# Knowledge Graph Configuration (Legacy)
KNOWLEDGE_GRAPH_BASE_URL=http://localhost:8001

# Multimodal Configuration
MULTIMODAL_PROVIDER=mock
MULTIMODAL_API_KEY=

# OCR Configuration
OCR_ENABLED=true

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Runtime dialog model configuration
DIALOG_PROVIDER=cliproxyapi
DIALOG_BASE_URL=https://api.aaccx.pw/v1
DIALOG_MODEL=gpt-5.4
DIALOG_REASONING_EFFORT=xhigh
DIALOG_API_KEY=sk-dummy

# Runtime knowledge build model configuration
KNOWLEDGE_BUILD_PROVIDER=cliproxyapi
KNOWLEDGE_BUILD_BASE_URL=https://api.aaccx.pw/v1
KNOWLEDGE_BUILD_MODEL=gpt-5.4
KNOWLEDGE_BUILD_REASONING_EFFORT=xhigh
KNOWLEDGE_BUILD_API_KEY=sk-dummy
